{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "代理控制器",
  "version": "0.1.0",
  "identifier": "com.noah.proxycontroller",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1650",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "代理控制器",
        "width": 720,
        "height": 520,
        "resizable": true,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
