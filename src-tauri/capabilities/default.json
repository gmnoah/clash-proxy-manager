{
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "shell:default",
    "fs:default",
    "fs:allow-exists",
    "fs:allow-mkdir",
    "fs:allow-read-text-file",
    "fs:allow-write-text-file",
    {
      "identifier": "shell:allow-execute",
      "allow": [
        {
          "name": "/bin/sh",
          "cmd": "/bin/sh",
          "args": true,
          "sidecar": false
        },
        {
          "name": "exec-sh",
          "cmd": "/bin/sh",
          "args": true,
          "sidecar": false
        }
      ]
    },
    {
      "identifier": "fs:scope",
      "allow": [
        { "path": "$HOME/.config/proxy-controller" },
        { "path": "$HOME/.config/proxy-controller/**" }
      ]
    }
  ]
}
